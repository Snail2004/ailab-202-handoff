{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ailab.local/schema/document.schema.json",
  "title": "AILAB Document",
  "description": "One source document of the EN-VI long-text dataset (AIL-202). Mirrors DATASET_DESIGN.md section 5.1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_id", "metadata", "chapters"],
  "$defs": {
    "span": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 2,
      "maxItems": 2,
      "description": "[start, end] character offset (end exclusive)"
    },
    "sentence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sent_id", "text"],
      "properties": {
        "sent_id": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "span": { "$ref": "#/$defs/span" }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_id", "order_index", "block_type", "source_text", "clean_text"],
      "properties": {
        "block_id": { "type": "string", "minLength": 1 },
        "order_index": { "type": "integer", "minimum": 0 },
        "page_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "block_type": {
          "enum": ["heading", "paragraph", "dialogue", "footnote"]
        },
        "is_chapter_opening": { "type": "boolean" },
        "source_text": { "type": "string", "minLength": 1 },
        "clean_text": { "type": "string", "minLength": 1 },
        "sentences": { "type": "array", "items": { "$ref": "#/$defs/sentence" } },
        "discourse": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "speaker_entity_id": { "type": ["string", "null"] },
            "addressee_entity_id": { "type": ["string", "null"] },
            "pronoun_hints": { "type": "array", "items": { "type": "string" } }
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": false,
          "description": "term_occurrences / entity_mentions are id pointers; authoritative spans live in glossary/entities files.",
          "properties": {
            "term_occurrences": { "type": "array", "items": { "type": "string" } },
            "entity_mentions": { "type": "array", "items": { "type": "string" } },
            "motifs": { "type": "array", "items": { "type": "string" } },
            "tone": { "type": ["string", "null"] },
            "implicit_meaning": { "type": ["string", "null"] },
            "narrative_note": { "type": ["string", "null"] }
          }
        },
        "reference_translation_id": { "type": ["string", "null"] },
        "quality_flags": { "type": "array", "items": { "type": "string" } },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "raw_span": { "anyOf": [{ "$ref": "#/$defs/span" }, { "type": "null" }] },
            "corrected_by": { "type": ["string", "null"] },
            "correction_note": { "type": ["string", "null"] }
          }
        }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chapter_id", "order_index", "blocks"],
      "properties": {
        "chapter_id": { "type": "string", "minLength": 1 },
        "order_index": { "type": "integer", "minimum": 0 },
        "title": { "type": "string" },
        "blocks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/block" } }
      }
    }
  },
  "properties": {
    "schema_version": { "const": "1.4.0" },
    "doc_id": { "type": "string", "minLength": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_language", "target_language", "source_format", "license", "contamination_risk", "pipeline_version"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "domain": { "type": "string" },
        "genre": { "type": "string" },
        "source_language": { "const": "en" },
        "target_language": { "const": "vi" },
        "source_format": { "enum": ["epub", "txt", "pdf", "html"] },
        "license": { "type": "string", "minLength": 1 },
        "license_url": { "type": "string" },
        "source_url": { "type": "string" },
        "raw_sha256": { "type": "string" },
        "retrieved_at": { "type": "string" },
        "extraction_tool": { "type": "string" },
        "pipeline_version": { "type": "string", "minLength": 1 },
        "contamination_risk": { "enum": ["low", "medium", "high"] }
      }
    },
    "chapters": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/chapter" } }
  }
}
