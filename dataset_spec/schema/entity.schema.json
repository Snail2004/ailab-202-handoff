{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ailab.local/schema/entity.schema.json",
  "title": "AILAB Entity",
  "description": "One entity record (one line of entities.jsonl). Mirrors DATASET_DESIGN.md section 5.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity_id", "doc_id", "canonical_source", "canonical_target", "entity_type", "mentions"],
  "$defs": {
    "span": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 2,
      "maxItems": 2
    }
  },
  "properties": {
    "entity_id": { "type": "string", "minLength": 1 },
    "doc_id": { "type": "string", "minLength": 1 },
    "canonical_source": { "type": "string", "minLength": 1 },
    "canonical_target": { "type": "string", "minLength": 1 },
    "entity_type": { "enum": ["person", "place", "org", "concept"] },
    "gender": { "enum": ["male", "female", "neutral", null] },
    "aliases_source": { "type": "array", "items": { "type": "string" } },
    "aliases_target": { "type": "array", "items": { "type": "string" } },
    "pronoun_policy": { "type": "string" },
    "mentions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["block_id", "surface"],
        "properties": {
          "block_id": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "span": { "$ref": "#/$defs/span" }
        }
      }
    },
    "annotated_by": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
